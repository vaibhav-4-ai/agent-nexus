# ==============================================================================
# agent-nexus Environment Configuration
# ==============================================================================
# Copy this file to .env and fill in your values.
# All services used here have FREE tiers that require NO credit card.
#
# Quick start:
#   1. cp .env.example .env
#   2. Fill in at least GROQ_API_KEY (get free at https://console.groq.com)
#   3. docker compose up   (local dev)
#   OR push to Hugging Face Spaces (production)
# ==============================================================================

# --- Application ---
ENVIRONMENT=development                    # development | staging | production
LOG_LEVEL=INFO                             # DEBUG | INFO | WARNING | ERROR

# ==============================================================================
# DATABASE — Neon.tech (Free Serverless PostgreSQL)
# Sign up: https://neon.tech (no credit card required)
# ==============================================================================
DB_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/agent_nexus
# For Neon production, use something like:
# DB_URL=postgresql+asyncpg://user:password@ep-cool-name-123456.us-east-2.aws.neon.tech/agent_nexus?sslmode=require
DB_POOL_SIZE=5
DB_POOL_PRE_PING=true
DB_ECHO=false
DB_AUTO_MIGRATE=true

# ==============================================================================
# REDIS — Upstash (Free Serverless Redis, 500K commands/month)
# Sign up: https://upstash.com (no credit card required)
# ==============================================================================
REDIS_URL=                                 # Leave empty to use in-memory fallback
REDIS_TOKEN=                               # Upstash REST token
REDIS_ENABLED=true
# For Upstash production, use something like:
# REDIS_URL=https://example-redis.upstash.io
# REDIS_TOKEN=Axxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ==============================================================================
# VECTOR DATABASE — Qdrant Cloud (Free 1GB cluster)
# Sign up: https://cloud.qdrant.io (no credit card required)
# ==============================================================================
VECTOR_PROVIDER=qdrant                     # qdrant | chroma
VECTOR_URL=http://localhost:6333           # Local Qdrant for dev
VECTOR_API_KEY=                            # Qdrant Cloud API key
VECTOR_EMBEDDING_MODEL=all-MiniLM-L6-v2   # Sentence-transformer model
VECTOR_EMBEDDING_DIMENSION=384             # Must match model output dim
# For Qdrant Cloud production:
# VECTOR_URL=https://your-cluster-id.region.aws.cloud.qdrant.io
# VECTOR_API_KEY=your_qdrant_api_key

# ==============================================================================
# LLM — Pick ONE path below.
#
# Path 1: Groq (default — free, no credit card; Llama-3.3-70B served fast)
# Path 2: BYOK — set GEMINI_API_KEY / OPENAI_API_KEY / ANTHROPIC_API_KEY + LLM_MODEL
# Path 3: Ollama (fully self-hosted; `docker compose --profile local up`)
# ==============================================================================
LLM_PROVIDER=groq                          # groq | openai | anthropic | gemini | ollama | vllm
LLM_MODEL=groq/llama-3.3-70b-versatile    # Default. Or: gemini/gemini-1.5-flash, gpt-4o-mini,
                                           #   claude-3-5-sonnet-latest, ollama/llama3.2:3b
LLM_VISION_MODEL=groq/llama-3.2-90b-vision-preview  # Vision model (optional)
LLM_TEMPERATURE=0.1
LLM_MAX_TOKENS=4096
LLM_MAX_RETRIES=3
LLM_TIMEOUT=120
LLM_FALLBACK_MODEL=groq/llama-3.1-8b-instant

# Provider API keys — only fill in the one(s) you'll use:
GROQ_API_KEY=                              # Get free at https://console.groq.com
GEMINI_API_KEY=                            # Get free at https://aistudio.google.com/apikey
OPENAI_API_KEY=                            # https://platform.openai.com
ANTHROPIC_API_KEY=                         # https://console.anthropic.com
OLLAMA_HOST=http://localhost:11434         # If running Ollama outside Docker

# ==============================================================================
# MCP — Tool Execution Configuration
# ==============================================================================
MCP_WORKSPACE_DIR=/tmp/agent-nexus-workspace  # Sandboxed workspace for tools
MCP_SHELL_TIMEOUT=30                       # Shell command timeout (seconds)
MCP_BROWSER_ENABLED=false                  # Playwright browser (needs ~400MB RAM)
MCP_SEARCH_PROVIDER=duckduckgo             # tavily | duckduckgo
MCP_TAVILY_API_KEY=                        # Get free at https://tavily.com (1000/mo)

# ==============================================================================
# MONITORING — DagsHub MLflow (Free managed MLflow server)
# Sign up: https://dagshub.com (no credit card required, use GitHub login)
# ==============================================================================
MONITORING_ENABLED=true
MONITORING_MLFLOW_TRACKING_URI=            # e.g. https://dagshub.com/user/agent-nexus.mlflow
MONITORING_MLFLOW_EXPERIMENT_NAME=agent-nexus
MONITORING_DAGSHUB_TOKEN=                  # DagsHub API token

# --- Quota auto-remediation (zero human intervention) ---
# Optional informational webhook. Works with Discord/Slack/ntfy.sh.
# Auto-eviction happens regardless of whether this is set.
ALERT_WEBHOOK_URL=                         # e.g. https://ntfy.sh/your-unique-topic
# Tunable thresholds (defaults are good for free-tier):
# MONITORING_QUOTA_QDRANT_THRESHOLD_BYTES=858993459   # 80% of 1 GB
# MONITORING_QUOTA_KG_ROW_THRESHOLD=8000
# MONITORING_TASK_CLEANUP_CUTOFF_S=86400              # 24h
# MONITORING_QUOTA_CHECK_INTERVAL_S=3600              # 1h

# ==============================================================================
# API — FastAPI Server Configuration
# ==============================================================================
API_HOST=0.0.0.0
API_PORT=7860                              # 7860 is required by HF Spaces
API_DEBUG=false
API_CORS_ORIGINS=[]                        # Origins allowed for CORS. Default: none.
                                           # Examples: ["https://your-frontend.example.com"]
                                           # ["*"] is allowed but forces allow_credentials=False
API_RATE_LIMIT=60/minute                   # Rate limit per client
API_KEY=                                   # Bearer-style key sent via X-API-Key header.
                                           # REQUIRED when ENVIRONMENT=production (else 503).
                                           # Generate: python -c "import secrets; print(secrets.token_urlsafe(32))"
